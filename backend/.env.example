# Copy to .env and fill in.

# Required for AI extraction & meal recommendations.
# Without it the backend still runs but falls back to a simple heuristic parser.
ANTHROPIC_API_KEY=sk-ant-...

# Claude model used for extraction / recommendations.
REELFIT_MODEL=claude-sonnet-4-6

# Optional: USDA FoodData Central key for food macro search.
# Get a free key at https://fdc.nal.usda.gov/api-key-signup.html
# "DEMO_KEY" works for light testing but is heavily rate-limited.
USDA_API_KEY=DEMO_KEY

# Optional shared secret. If set, the iOS app must send it as
# the "X-ReelFit-Token" header. Leave blank for local dev.
REELFIT_API_TOKEN=

# Strava integration (to import your Coros runs that auto-export to Strava).
# Create an API app at https://www.strava.com/settings/api and set its
# "Authorization Callback Domain" to: reelfit.app
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
